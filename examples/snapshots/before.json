{
  "version": "v1",
  "cluster": "demo",
  "namespace": "prod",
  "created_at": "2026-04-25T14:00:00Z",
  "resources": [
    {
      "kind": "Deployment",
      "namespace": "prod",
      "name": "api",
      "deployment": {
        "replicas": 3,
        "containers": [
          {
            "name": "api",
            "image": "api:v1.0.0",
            "resources": {
              "memory_limit": "512Mi"
            },
            "env": [
              {
                "name": "DB_POOL_SIZE",
                "type": "literal",
                "value": "20"
              }
            ]
          }
        ]
      }
    },
    {
      "kind": "ConfigMap",
      "namespace": "prod",
      "name": "api-config",
      "config_map": {
        "data": {
          "DB_POOL_SIZE": "20"
        }
      }
    }
  ]
}
